# Same key as app.json's android.config.googleMaps.apiKey, with the "Places API"
# (not just "Maps SDK for Android") enabled on it. Powers live search suggestions
# on the Start Journey screen. Optional - search still works without it via
# plain geocoding, just without autocomplete-as-you-type.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
